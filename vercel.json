{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": { "memory": 512, "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/v1/(.*)",      "destination": "/api/index" },
    { "source": "/api/reconcile", "destination": "/api/index" }
  ],
  "crons": [
    {
      "path": "/api/reconcile",
      "schedule": "0 7 * * *"
    }
  ]
}
