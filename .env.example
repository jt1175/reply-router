# Anthropic — shared across all clients
ANTHROPIC_API_KEY=sk-ant-...

# Per-client secrets. Each clients/<id>.json references these by name.
CFS_GHL_API_KEY=
CFS_SMARTLEAD_API_KEY=
CFS_SLACK_WEBHOOK_URL=
CFS_ROUTER_SECRET=                # generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Vercel injects automatically for cron auth — only needed locally
VERCEL_CRON_SECRET=
